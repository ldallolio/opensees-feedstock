-                CALL ACTIVATE_SURFACE(N-1,SIGMA,0D0)
-                
-            ELSE                                 ! POPULATE THE CURRENT SURFACE
-
-                  IF(N.LE.NSURFACE) THEN
-                
-                      SURFACE = N
