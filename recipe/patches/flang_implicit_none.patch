-    SUBROUTINE OPTIMISE ()
-        
-        !DSIJ                : INCREMENTAL STRESS RATIO
-        !XIJE                : CONJUGATE POINT BASED ON ELASTIC RESPONSE
-        !XIJP                : CONJUGATE POINT BASED ON PLASTIC RESPONSE
-        !XIJA                : CONJUGATE POINT BASED ON ASSUMPTION
