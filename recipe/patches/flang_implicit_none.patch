-
-        DENOMINATOR = NIJ.DDOT.(SIGMA_R-SIGMA)
-
-         IF(DABS(DENOMINATOR).LE.TINY(1D0)) THEN
-            Z = SIGMA_C
-            RETURN
-         ELSE    
-            BETA = 0.5D0*NUMERATOR/((NIJ.DDOT.(SIGMA_R-SIGMA)))
