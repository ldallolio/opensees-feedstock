-        REAL(KIND=DBL)::TEMP(SIZE_PROB,SIZE_PROB),DELG(3,1),DELF(3,1),DENOMINATOR,CORRECTOR(3,3)
-        DELG = 0D0 ! VECTOR FORM OF PLASTIC_POTENTIAL
-        DELF = 0D0 ! VECTOR FORM OF LOADING_POTENTIAL
