+                        TENSORMULTIPLY422%COMPONENT(I,J)=TENSORMULTIPLY422%COMPONENT(I,J)+ &
+                        & DATA1%COMPONENT(I,J,K,L)*DATA2%COMPONENT(K,L)
+                     END DO
+                END DO
+            END DO
