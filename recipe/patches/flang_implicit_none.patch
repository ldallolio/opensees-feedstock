-        
-        !DGAMMA = 2.0D0*SECINVDEV(STRAIN_TENSOR_NEXT-STRAIN_TENSOR_CURRENT)
-        DGAMMA = 2.0D0*SECINVDEV(DEPSILON)
-        !WRITE(*,*)'DGAMMA',DGAMMA
